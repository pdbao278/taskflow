* text=auto

# Keep shell scripts runnable on Unix.
*.sh text eol=lf

# Prefer LF for common text files to avoid noisy diffs.
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.txt text eol=lf

